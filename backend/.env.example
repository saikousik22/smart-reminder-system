# Copy this file to .env and fill in real values before running the app.
# NEVER commit .env to version control.

# App
DEBUG=True

# Database
DATABASE_URL=sqlite:///./reminders.db

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<replace-with-a-strong-random-secret>

# Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Public URL reachable by Twilio (use ngrok locally)
# npx ngrok http 8000  → copy the https URL here
PUBLIC_BASE_URL=https://<your-ngrok-id>.ngrok-free.app

# Redis (Celery broker + result backend)
REDIS_URL=redis://localhost:6379/0

# CORS — comma-separated list of allowed frontend origins
# CORS_ORIGINS=["http://localhost:5173"]

# Set True in production (requires HTTPS cookies)
# COOKIE_SECURE=False
